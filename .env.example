# Ephemera Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# Error Tracking - Sentry (optional)
# ===========================================
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
VITE_SENTRY_ENVIRONMENT=production

# ===========================================
# CORS Proxy (optional)
# ===========================================
# PROXY_URL=https://your-proxy.example.com/

# ===========================================
# ChatGPT OAuth (optional - for ChatGPT Plus/Pro subscription support)
# ===========================================
# Client-side (exposed to browser)
# VITE_OPENAI_OAUTH_CLIENT_ID=
# VITE_APP_URL=https://your-domain.com
# Server-side only (Vercel serverless functions)
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=
