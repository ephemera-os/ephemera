# Ephemera Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# Error Tracking - Sentry (optional)
# ===========================================
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
VITE_SENTRY_ENVIRONMENT=production

# ===========================================
# CORS Proxy (optional)
# ===========================================
# PROXY_URL=https://your-proxy.example.com/

# ===========================================
# ChatGPT Plus/Pro server session auth (optional)
# ===========================================
# Browser origin and API base path (optional; defaults work for same-origin setups)
# VITE_APP_URL=https://your-domain.com
# Optional override for AI auth API path (defaults to /api for root, or <BASE_URL>/api for subpath builds)
# VITE_AI_OAUTH_API_BASE_PATH=/ephemera/api
# Server-side optional override (defaults to official Codex public client id)
# OPENAI_CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
